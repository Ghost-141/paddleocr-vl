# Public API
PUBLIC_API_KEY=
APP_PORT=8080

# GPU and PaddleX HPS
GPU_DEVICE_ID=0
LAYOUT_DEVICE=cpu
PADDLEX_HPS_USE_HPIP=0

# PDF queue and worker reliability
MAX_FILE_SIZE_MB=100
MAX_PAGES=100
MAX_JOBS=20
# Bounded producer depth for one PDF.  With two active PDFs, 3 produces 6 pages.
MAX_PAGES_PER_JOB=12
MAX_REGIONS_PER_PAGE=64
# Fixed producer/consumer pools for one on-prem GPU.
LAYOUT_REPLICAS=6
LAYOUT_THREADS=4
LAYOUT_WORKER_REPLICAS=6
VLM_WORKER_REPLICAS=48
LEASE_SECONDS=900
MAX_RETRIES=3
RETENTION_HOURS=24

# Model download; optional for public Hugging Face models
HF_TOKEN=

# Override only when using a different compatible PaddleOCR vLLM image
VLLM_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-genai-vllm-server:latest-nvidia-gpu-offline
