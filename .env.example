# Public API
PUBLIC_API_KEY=
APP_PORT=8080

# GPU
GPU_DEVICE_ID=0

# PDF queue and worker reliability
MAX_FILE_SIZE_MB=100
MAX_PAGES=100
MAX_JOBS=20

# Bounded producer depth for one PDF. With two active PDFs, 12 permits 24 pages in flight.
MAX_PAGES_PER_JOB=12
MAX_REGIONS_PER_PAGE=64

# Fixed producer/consumer pools for one on-prem GPU.
LAYOUT_WORKER_REPLICAS=6
# Four async dispatchers × 32 in-flight vLLM requests = 128 requests maximum.
VLM_WORKER_REPLICAS=4
VLM_DISPATCH_CONCURRENCY=32
VLM_CLAIM_BATCH_SIZE=32
LEASE_SECONDS=900
MAX_RETRIES=3
RETENTION_HOURS=24

# Model download; optional for public Hugging Face models
HF_TOKEN=

# Direct vLLM recognition service; override only for a compatible image/model.
VLLM_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-genai-vllm-server:latest-nvidia-gpu-offline
VLLM_MODEL=PaddleOCR-VL-1.6-0.9B
